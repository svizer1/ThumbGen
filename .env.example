# Optional: specific replicate model string 
REPLICATE_MODEL=stability-ai/sdxl:7762fd07cf82c948538e41f63f77d685e02b063e37291af9e450672548b2c357

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# CryptoBot API
CRYPTOBOT_API_TOKEN=your_cryptobot_api_token_here