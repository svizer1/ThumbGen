# Which image provider to use: "mock" | "replicate" | "fal" | "stability" 
IMAGE_PROVIDER=mock 

# Replicate ( `https://replicate.com)` 
REPLICATE_API_KEY= 

# Fal.ai ( `https://fal.ai)` 
