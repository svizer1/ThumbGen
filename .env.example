# ============================================
# AI Image Generation Providers (2026)
# ============================================

# Bytez API (Рекомендуется)
# Доступ к Google Imagen, FLUX, Stable Diffusion
# Получить ключ: https://bytez.com/
BYTEZ_API_KEY=your_bytez_api_key_here

# Groq API (Prompt Enhancement)
# Быстрая и надежная модель для улучшения промптов
# Получить ключ: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio (Бесплатно 500 запросов/день) ⭐
# Nano Banana, Nano Banana 2 (с image-to-image)
# Получить ключ: https://aistudio.google.com/
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Hugging Face (Ограниченный бесплатный tier) ⚠️
# ВНИМАНИЕ: В 2026 большинство моделей требуют платные кредиты
# Получить ключ: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Hugging Face API Key (public for client-side)
NEXT_PUBLIC_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Unsplash API (Reference Image Search)
# Получить ключ: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Image Provider (optional, for default)
IMAGE_PROVIDER=bytez

# ============================================
# Firebase Configuration
# ============================================

# reCAPTCHA v2 Keys
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Firebase Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (server-side)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# ============================================
# Telegram Bot & Payment
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# CryptoBot API
CRYPTOBOT_API_TOKEN=your_cryptobot_api_token_here